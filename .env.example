# FitLife Pro — copy to `.env` in this folder (next to package.json), then fill in real values.
# Restart dev server after any change:  npm run dev

VITE_API_URL=http://localhost:8000

# Firebase Web App — Firebase Console → Project settings → Your apps → Web app
# Paste the exact strings from the firebaseConfig object (apiKey usually starts with AIza).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional
VITE_FIREBASE_MEASUREMENT_ID=
