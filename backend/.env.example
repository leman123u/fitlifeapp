# --- MongoDB (optional if USE_MOCK_DB=1) ---
# In-memory mock DB for local UI testing without Atlas. Set to 0 for real MongoDB.
USE_MOCK_DB=1

# With USE_MOCK_DB=1: verify API calls with Authorization: Bearer <MOCK_BEARER_TOKEN> (default dev-mock-token)
# without Firebase Admin SDK. Set MOCK_AUTH=0 when using GOOGLE_APPLICATION_CREDENTIALS.
MOCK_AUTH=1
MOCK_BEARER_TOKEN=dev-mock-token

# Connection string: Atlas → Connect → Drivers → copy URI (replace <password>)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net
MONGODB_DB_NAME=fitlife_pro

# --- JWT ---
# Use a long random string (e.g. openssl rand -hex 32). Do not reuse across environments.
JWT_SECRET=

# --- HTTP port ---
# Local uvicorn. On Google App Engine, the platform sets PORT; your app should read that.
PORT=8000

# --- CORS (browser origins allowed to call this API) ---
# Option A: comma-separated list (overrides Option B)
# CORS_ORIGINS=http://localhost:3000,https://your-app.pages.dev
# Option B: default localhost:3000 + your Cloudflare Pages / custom domain
CLOUDFLARE_FRONTEND_URL=https://your-app.pages.dev

# --- Firebase Admin SDK ---
# Download JSON: Firebase Console → Project settings → Service accounts → Generate new private key
# Put the file under backend/secrets/ (gitignored) or backend/ and point one of these vars at it.
# Relative paths are resolved from the current working directory and from the backend/ folder.
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-adminsdk.json
# Alternative (Google standard name; optional if FIREBASE_SERVICE_ACCOUNT_PATH is set):
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/firebase-adminsdk.json
